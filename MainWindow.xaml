<Window x:Class="SynthModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synth Riders Mod Manager"
        Width="960" Height="640" MinWidth="760" MinHeight="480"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="130"/>
        </Grid.RowDefinitions>

        <!-- Header: game path + MelonLoader status -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Game folder:" Foreground="{StaticResource SubtleBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="GamePathBox" IsReadOnly="True"
                         Background="#FF1B1B26" Foreground="{StaticResource TextBrush}"
                         BorderThickness="0" Padding="8,6" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="Browse…" Margin="8,0,0,0" Click="Browse_Click"/>
                <Button Grid.Column="3" Content="Refresh" Margin="8,0,0,0" Click="Refresh_Click"/>
                <Border Grid.Column="4" Margin="12,0,0,0" CornerRadius="6" Padding="10,6"
                        Background="#FF1B1B26" VerticalAlignment="Center">
                    <TextBlock x:Name="MelonStatus" Text="MelonLoader: checking…" Foreground="{StaticResource SubtleBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Mod list -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="4">
            <ListView x:Name="ModList" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource TextBrush}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF1F1F2C" CornerRadius="8" Padding="12" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Author, StringFormat=' by {0}'}" FontSize="12"
                                                   Foreground="{StaticResource SubtleBrush}" VerticalAlignment="Bottom" Margin="6,0,0,1"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12"
                                               Foreground="{StaticResource SubtleBrush}" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,6,0,0"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{Binding LatestVersion}" VerticalAlignment="Center"
                                           Foreground="{StaticResource SubtleBrush}" Margin="12,0"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="{Binding ActionLabel}" MinWidth="88"
                                            IsEnabled="{Binding NotBusy}"
                                            Click="InstallOrUpdate_Click" Tag="{Binding}"/>
                                    <Button Content="Uninstall" MinWidth="80" Margin="8,0,0,0"
                                            Background="#FF4C3A3A"
                                            Click="Uninstall_Click" Tag="{Binding}"
                                            IsEnabled="{Binding CanUninstall}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Log -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="8" Margin="0,10,0,0">
            <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                     Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource SubtleBrush}" FontFamily="Consolas" FontSize="12"
                     VerticalScrollBarVisibility="Auto"/>
        </Border>
    </Grid>
</Window>
